# =============================================
# job.bar Backend — Environment Variables
# Copy this to .env and fill in your values
# =============================================

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/jobbar
# For Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/jobbar

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_token_secret_also_change_this
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=uploads

# RapidAPI (for live job fetching)
RAPIDAPI_KEY=your_rapidapi_key
RAPIDAPI_HOST=jsearch.p.rapidapi.com

# Redis (optional, for Bull queue)
REDIS_URL=redis://localhost:6379

# Admin
ADMIN_EMAIL=admin@jobbar.com

# Analytics
ENABLE_ANALYTICS=true
